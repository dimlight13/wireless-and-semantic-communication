{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run visualization server",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "env": {
                "PORT": "8000"
            },
            "serverReadyAction": {
                "pattern": ".*(http://127\\.0\\.0\\.1:[0-9]+).*",
                "uriFormat": "%s",
                "action": "openExternally"
            }
        },
        {
            "name": "Open visualization in Chrome",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8000",
            "webRoot": "${workspaceFolder}"
        }
    ]
}
